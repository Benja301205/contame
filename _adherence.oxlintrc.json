{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "ui_kits/dashboard/**",
              "ui_kits/survey-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Instrument Serif|Space Grotesk|JetBrains Mono|Bebas Neue))/i]",
        "message": "Font not provided by the design system. Available: Instrument Serif, Space Grotesk, JetBrains Mono, Bebas Neue."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|status|tone|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, status, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:pill|tag)$/]",
        "message": "<Badge> variant must be one of 'pill' | 'tag'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:online|offline|live)$/]",
        "message": "<Badge> status must be one of 'online' | 'offline' | 'live'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:alta|media|baja|soft)$/]",
        "message": "<Badge> tone must be one of 'alta' | 'media' | 'baja' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|arrow|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, arrow, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|stamp|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'stamp' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:accent|fill|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: accent, fill, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='fill'] > Literal[value!=/^(?:fill|gradient)$/]",
        "message": "<Card> fill must be one of 'fill' | 'gradient'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dot|tone|className|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, dot, tone, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:hot)$/]",
        "message": "<Eyebrow> tone must be one of 'hot'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeatMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|labels|name|key|ref|className|style|children)$/]",
        "message": "<HeatMeter> doesn't accept that prop. Declared props: value, onChange, labels, name."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|caption|value|max|tone|key|ref|className|style|children)$/]",
        "message": "<MetricBar> doesn't accept that prop. Declared props: label, caption, value, max, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:low)$/]",
        "message": "<MetricBar> tone must be one of 'low'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Quote'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|children|meta|mark|key|ref|className|style|children)$/]",
        "message": "<Quote> doesn't accept that prop. Declared props: category, children, meta, mark."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCardBreakdownCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|tone|key|ref|className|style|children)$/]",
        "message": "<StatCardBreakdownCell> doesn't accept that prop. Declared props: value, label, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCardBreakdownCell'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:positive|warning|negative)$/]",
        "message": "<StatCardBreakdownCell> tone must be one of 'positive' | 'warning' | 'negative'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|multiline|value|onChange|placeholder|rows|meta|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, multiline, value, onChange, placeholder, rows, meta."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
